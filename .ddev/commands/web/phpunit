#!/bin/bash
## Description: Run PHPUnit inside the ddev web container
## Usage: phpunit [phpunit-args]
## Example: "ddev phpunit --testdox"

WORKSPACE="${SEILER_DDEV_DIR:-/workspace}"
cd "$WORKSPACE" || exit 1

# Auto-detect phpunit bin: src/vendor first (phpunit-setup preference when
# src/composer.json exists), then root vendor. Override via SEILER_PHPUNIT_BIN.
if [ -n "$SEILER_PHPUNIT_BIN" ]; then
  PHPUNIT_BIN="$SEILER_PHPUNIT_BIN"
elif [ -x src/vendor/bin/phpunit ]; then
  PHPUNIT_BIN="src/vendor/bin/phpunit"
elif [ -x vendor/bin/phpunit ]; then
  PHPUNIT_BIN="vendor/bin/phpunit"
else
  echo "phpunit not found in src/vendor/bin/ or vendor/bin/" >&2
  echo "Run \`bunx seiler-phpunit-setup\` to install." >&2
  exit 1
fi

exec "$PHPUNIT_BIN" "$@"
